# =============================================================================
# NekoProjectBackend 环境变量示例 —— 复制为 .env 后按本地环境修改取值。
# -----------------------------------------------------------------------------
# 加载机制：application.yaml 通过 spring.config.import 读取同目录 .env
#           (optional:file:.env[.properties])，把变量注入 Spring Environment，
#           再替换 application.yaml / application-prod.yaml 里的 ${ENV:默认值} 占位符。
#
# 命名约定：
#   - DEV 默认值已填好，复制即可本地启动（profile 缺省 = dev，开箱即用）。
#   - 标 ⚠️ 的是「生产必须显式设置 / 与 dev 取值不同」的项，见文末「生产部署」一节。
#   - 标 🔒 的是机密项，绝不写进仓库，生产用部署平台 / 环境变量注入。
# =============================================================================


# ───────────────────────── Spring Profile ─────────────────────────
# 激活哪个 profile：留空 / development = dev（application.yaml）；
#                 prod = 叠加 application-prod.yaml（强制 cookie.secure、ddl-auto=update 等）。
# 本地开发留空即可；生产部署设 prod。
SPRING_PROFILES_ACTIVE=


# ───────────────────────── 服务器 ─────────────────────────
# HTTP 监听端口
SERVER_PORT=8080


# ───────────────────────── Web 服务器（Jetty） ─────────────────────────
# 线程池：min/max 决定并发处理上限；acceptors/selectors 保持 -1（按 CPU 核数自动）
JETTY_THREADS_ACCEPTORS=-1
JETTY_THREADS_SELECTORS=-1
JETTY_THREADS_MIN=8
JETTY_THREADS_MAX=200
# 工作线程空闲回收时长
JETTY_THREADS_IDLE_TIMEOUT=60s
# 同时接受并处理的最大连接数；-1 = 不限
JETTY_MAX_CONNECTIONS=-1
# HTTP 响应头最大尺寸
JETTY_MAX_RESPONSE_HEADER_SIZE=16KB
# 访问日志（默认关闭）；开启后 FILENAME 留空则输出到 stderr
JETTY_ACCESS_LOG_ENABLED=false
JETTY_ACCESS_LOG_FILENAME=
JETTY_ACCESS_LOG_APPEND=false
JETTY_ACCESS_LOG_RETENTION_DAYS=31


# ───────────────────────── 数据库（PostgreSQL） ─────────────────────────
# JDBC 连接 URL
DB_URL=jdbc:postgresql://localhost:5432/nekoBackend
DB_USERNAME=nekoBackend
# 🔒 数据库密码
DB_PASSWORD=change-me
# Hibernate DDL 策略：
#   create   = 每次启动丢表重建（仅本地开发用，数据全没）
#   update   = 增量补表 / 列，不删现有数据（生产 profile 强制用此项）
#   validate = 只校验不改动
DB_HIBERNATE_DDL_AUTO=create


# ───────────────────────── Redis ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 🔒 Redis 密码
REDIS_PASSWORD=change-me
# 逻辑库编号
REDIS_DATABASE=4
# 连接 / 命令超时
REDIS_TIMEOUT=10000ms
# 应用启动时是否 FLUSHDB 清空 Redis（本地 / 测试重置数据用；生产务必设 false）
REDIS_CLEAR_ON_STARTUP=true


# ───────────────────────── JWT ─────────────────────────
# 🔒 HMAC 签名密钥：生产必须替换为 ≥32 字节随机串，泄露即等于所有 token 可被伪造
JWT_SECRET=replace-with-at-least-32-bytes-random-string
# iss 声明（签发者标识，校验时比对）
JWT_ISSUER=NekoBackend
# 访问令牌有效期（秒）：7200 = 2h
JWT_ACCESS_TOKEN_TTL_SECONDS=7200
# 刷新令牌有效期（秒）：604800 = 7d，配合下方 Cookie 下发
JWT_REFRESH_TOKEN_TTL_SECONDS=604800


# ───────────────────────── 刷新令牌 Cookie（HttpOnly，前端 JS 不可读） ─────────────────────────
# 开发：本地 http、同站，secure=false、same-site=Lax 即可。
# 生产：prod profile 强制 secure=true 且走 HTTPS；跨根域部署时 COOKIE_SAME_SITE 设 None。
COOKIE_NAME=nekobox_refresh
# Cookie 作用域；留空 = 仅当前域，跨子域共享才需设置
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
# SameSite 策略：Lax（同站）/ None（跨站，需 secure）/ Strict
COOKIE_SAME_SITE=Lax


# ───────────────────────── 邮件（SMTP） ─────────────────────────
MAIL_HOST=smtp.example.com
# 端口：25 明文 / 587 STARTTLS / 465 SSL
MAIL_PORT=587
MAIL_USERNAME=notice@example.com
# 🔒 SMTP 登录密码
MAIL_PASSWORD=change-me
MAIL_SMTP_AUTH=true
# 465 端口通常为 true；587 端口保持 false 走 STARTTLS
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=10000
MAIL_SMTP_READ_TIMEOUT=10000
MAIL_SMTP_WRITE_TIMEOUT=10000
# 发件人地址；留空则回退到 MAIL_USERNAME
MAIL_FROM=notice@example.com


# ───────────────────────── 邮箱验证码 ─────────────────────────
# 验证码有效期（秒）：600 = 10min
MAIL_VERIFICATION_TTL_SECONDS=600
# 验证码位数
MAIL_VERIFICATION_CODE_LENGTH=6
# 同一邮箱两次发送的最小间隔（秒），防轰炸
MAIL_VERIFICATION_SEND_INTERVAL=60
# 单邮箱每日发送上限（次）
MAIL_VERIFICATION_DAILY_LIMIT=10
# 验证码邮件主题前缀
MAIL_VERIFICATION_SUBJECT_PREFIX=NekoBackend


# ───────────────────────── 文件上传 / 下载 ─────────────────────────
# 文件落盘根目录
FILE_STORAGE_PATH=./storage
# 文件访问基础 URL（拼接对外下载链接用）
FILE_BASE_URL=http://localhost:8080
# 图片是否允许匿名（无 JWT）读取
FILE_PUBLIC_READ_IMAGE=true
# 私有下载签名 token 有效期（秒）：300 = 5min
FILE_DOWNLOAD_TOKEN_TTL=300
# 各类型允许的扩展名（逗号分隔）与单文件大小上限（MB）
FILE_IMAGE_ALLOWED_EXT=jpg,jpeg,png,gif,webp,bmp,svg
FILE_IMAGE_MAX_MB=10
FILE_DOC_ALLOWED_EXT=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,md,csv,zip
FILE_DOC_MAX_MB=20
# Spring multipart 硬上限，必须 >= 上面最大的 FILE_*_MAX_MB，否则会在 Servlet 层先拒绝上传
FILE_MAX_SIZE=20MB
FILE_MAX_REQUEST_SIZE=20MB


# ───────────────────────── 初始管理员（AdminUserSeeder） ─────────────────────────
# 首次启动由 AdminUserSeeder 写入；按用户名判断已存在则跳过（不覆盖现有密码）。
# dev profile 读 ADMIN_*；prod profile 读 NEKO_ADMIN_*（见 application-prod.yaml）。
# ⚠️ prod 守卫：NEKO_ADMIN_PASSWORD 为空或等于 "password" 时拒绝初始化超管，防后门。
#              生产务必通过 NEKO_ADMIN_PASSWORD 注入强口令，否则默认管理员不会被创建。
# dev / test 放行弱默认口令，本地可用 admin/password 登录开发。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
ADMIN_EMAIL=admin@nekobox.local
# —— 以下仅 prod profile 生效（application-prod.yaml 读取）——
NEKO_ADMIN_USERNAME=admin
# 🔒 生产超管口令，必须设强口令（留空或 "password" 会被 seeder 拒绝）
NEKO_ADMIN_PASSWORD=
NEKO_ADMIN_EMAIL=admin@nekobox.local


# ───────────────────────── 邀请码 ─────────────────────────
# 邀请码有效期（秒）：604800 = 7d
INVITE_TTL_SECONDS=604800


# ───────────────────────── 项目 ─────────────────────────
# 单个项目经理最多持有的项目数
PROJECT_MAX_PER_MANAGER=10


# ───────────────────────── 操作审计日志 ─────────────────────────
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/operation.log
AUDIT_MAX_SIZE_MB=50
AUDIT_MAX_ARCHIVES=30
# 是否信任 X-Forwarded-For / X-Real-IP：仅在可信反代（Nginx/网关）后才开启，
# 否则客户端可伪造审计 IP。dev 保持 false 用 remoteAddr。
AUDIT_TRUST_FORWARDED=false


# ───────────────────────── 可信反代（neko.security.trusted-proxy） ─────────────────────────
# clientIp 是否采信 X-Forwarded-For / X-Real-IP。
# 与 AUDIT_TRUST_FORWARDED 含义一致但作用域不同：此处影响 IP 维度限流 / 安全审计取址。
# ⚠️ 生产部署在 Nginx / 网关后才设 true；否则保持 false 防 XFF 伪造绕过限流。
NEKO_TRUSTED_PROXY=false


# ───────────────────────── 内容审核 ─────────────────────────
# 评论 / 想法等 UGC 新建后的初始状态：
#   true  = 开启审核，新建置 PENDING 待管理员审核通过后公开（默认）
#   false = 临时关闭审核，新建直接 APPROVED 立即公开
MODERATION_ENABLED=true


# ───────────────────────── 数据 Seeder ─────────────────────────
# 是否在启动时执行数据 Seeder（初始管理员、演示数据等）
SEED_ENABLED=true


# =============================================================================
# 生产部署清单（SPRING_PROFILES_ACTIVE=prod 时必须检查）
# -----------------------------------------------------------------------------
# 1. SPRING_PROFILES_ACTIVE=prod
# 2. 🔒 DB_PASSWORD / REDIS_PASSWORD / JWT_SECRET / MAIL_PASSWORD → 注入真实强值
# 3. 🔒 NEKO_ADMIN_PASSWORD → 强口令（留空或 "password" 会被 seeder 拒绝，超管不创建）
# 4. DB_HIBERNATE_DDL_AUTO → prod profile 已强制 update，无需手动设；切勿用 create
# 5. REDIS_CLEAR_ON_STARTUP=false（避免启动清空线上缓存）
# 6. COOKIE_SAME_SITE → 跨根域部署设 None（prod 已强制 secure=true）
# 7. NEKO_TRUSTED_PROXY / AUDIT_TRUST_FORWARDED → 仅在可信反代后设 true
# 8. FILE_BASE_URL → 对外可访问的下载基址（非 localhost）
# =============================================================================
